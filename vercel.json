{
  "redirects": [
    { "source": "/events", "destination": "https://booking.artbar.co.jp", "permanent": false },
    { "source": "/events/(.*)", "destination": "https://booking.artbar.co.jp/$1", "permanent": false },
    { "source": "/calendar", "destination": "/", "permanent": true },
    { "source": "/about/instructors", "destination": "/instructors", "permanent": true },
    { "source": "/contact-us", "destination": "/contact", "permanent": true },
    { "source": "/contact-en", "destination": "/contact", "permanent": true },
    { "source": "/contact-en/", "destination": "/contact", "permanent": true },
    { "source": "/category/:slug", "destination": "/blog", "permanent": true },
    { "source": "/:year(\\d{4})/:month(\\d{2})/:slug", "destination": "/blog/:slug", "permanent": true }
  ],
  "headers": [
    {
      "source": "/media/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
